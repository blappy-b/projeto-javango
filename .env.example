# ============================================================================
# ARQUIVO DE EXEMPLO DE VARIÁVEIS DE AMBIENTE
# ============================================================================
# Copie este arquivo para `.env.local` e preencha com suas credenciais.
# NUNCA commite o arquivo .env.local no repositório!
#
# Comando para copiar:
#   cp .env.example .env.local
# ============================================================================

# ============================================================================
# SUPABASE - Banco de dados e autenticação
# ============================================================================
# Onde conseguir:
#   1. Acesse https://supabase.com e faça login
#   2. Crie um novo projeto ou selecione um existente
#   3. Vá em "Project Settings" (ícone de engrenagem) > "API"
#   4. As chaves estarão na seção "Project API keys"
#
# URL do Projeto:
#   - Encontrada em "Project Settings" > "Data API" > "Project URL"
#   - Formato: https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave Anônima (anon/public):
#   - Encontrada em "Project Settings" > "API" > "Project API keys" > "anon public"
#   - Esta chave é PÚBLICA e pode ser exposta no frontend
#   - Usada para operações que respeitam as políticas RLS (Row Level Security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...sua-chave-anon

# Chave de Serviço (service_role):
#   - Encontrada em "Project Settings" > "API" > "Project API keys" > "service_role"
#   - ⚠️  ATENÇÃO: Esta chave é SECRETA e NUNCA deve ser exposta no frontend!
#   - Ignora todas as políticas RLS - use apenas no servidor
#   - Usada para operações administrativas (webhooks, validação de tickets, etc.)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...sua-chave-service-role

# ============================================================================
# SUPABASE STORAGE - Armazenamento de imagens
# ============================================================================
# Nome do bucket para armazenar imagens de eventos
# Onde configurar:
#   1. No painel do Supabase, vá em "Storage"
#   2. Clique em "New bucket"
#   3. Crie um bucket chamado "event-images" (ou outro nome de sua escolha)
#   4. Configure as políticas de acesso do bucket conforme necessário
#
# Se não definido, o padrão é "event-images"
SUPABASE_EVENT_IMAGES_BUCKET=event-images

# ============================================================================
# APLICAÇÃO
# ============================================================================
# URL base da aplicação
#
# Para que serve:
#   - URLs de callback do Mercado Pago (sucesso, falha, pendente)
#   - URLs de notificação de webhooks
#   - Links compartilháveis
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  ⚠️  DESENVOLVIMENTO LOCAL COM WEBHOOKS DO MERCADO PAGO                 │
# │                                                                         │
# │  Para testar webhooks do Mercado Pago localmente, você PRECISA usar    │
# │  ngrok (ou similar) porque o Mercado Pago não consegue acessar         │
# │  localhost diretamente.                                                 │
# │                                                                         │
# │  Passo a passo:                                                         │
# │    1. Instale ngrok: https://ngrok.com/download                        │
# │    2. Inicie o túnel: npx ngrok http 3000                              │
# │    3. Copie a URL HTTPS gerada (ex: https://abc123.ngrok.io)           │
# │    4. Cole aqui em NEXT_PUBLIC_BASE_URL                                │
# │    5. Configure essa mesma URL no painel do Mercado Pago (webhooks)    │
# │                                                                         │
# │  Lembre-se: A URL do ngrok muda a cada reinício (versão gratuita).     │
# │  Atualize tanto aqui quanto no painel do Mercado Pago se reiniciar.    │
# └─────────────────────────────────────────────────────────────────────────┘
#
# Valores por ambiente:
#   - Desenvolvimento SEM webhooks: http://localhost:3000
#   - Desenvolvimento COM webhooks: https://seu-subdominio.ngrok.io  👈 USE NGROK!
#   - Produção: https://seu-dominio.com
#
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# NEXT_PUBLIC_BASE_URL=https://abc123.ngrok.io  # 👈 Descomente e ajuste para testar webhooks

# ============================================================================
# SEGURANÇA - QR Code dos Tickets
# ============================================================================
# Segredo para assinar e validar QR codes dos tickets
# Como gerar:
#   Opção 1 - Via Node.js:
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
#   Opção 2 - Via OpenSSL:
#     openssl rand -hex 32
#
#   Opção 3 - Via PowerShell:
#     [Convert]::ToHexString([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32)).ToLower()
#
# ⚠️  IMPORTANTE:
#   - Use uma string aleatória de pelo menos 32 caracteres
#   - NUNCA compartilhe este segredo
#   - Se vazado, todos os QR codes existentes se tornam vulneráveis
TICKET_QR_SECRET=sua-chave-secreta-muito-longa-e-aleatoria-aqui

# ============================================================================
# MERCADO PAGO - Processamento de pagamentos
# ============================================================================
# Onde conseguir:
#   1. Acesse https://www.mercadopago.com.br/developers
#   2. Faça login com sua conta do Mercado Pago
#   3. Vá em "Suas integrações" > "Criar aplicação" (ou selecione uma existente)
#   4. Em "Credenciais de produção" ou "Credenciais de teste":
#      - Copie o "Access Token"
#
# Credenciais de TESTE (sandbox):
#   - Use para desenvolvimento e testes
#   - Encontradas em "Credenciais de teste"
#   - Permite simular pagamentos sem dinheiro real
#   - Crie contas de teste em: https://www.mercadopago.com.br/developers/panel/app/{APP_ID}/test-accounts
#
# Credenciais de PRODUÇÃO:
#   - Use apenas em ambiente de produção
#   - Encontradas em "Credenciais de produção"
#   - Processa pagamentos reais
#   - ⚠️  Só ative após testar completamente com credenciais de teste!
#
# Formato do token:
#   - Teste: APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#   - Produção: APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000

# ============================================================================
# CONFIGURAÇÃO DE WEBHOOKS DO MERCADO PAGO
# ============================================================================
# Após configurar as variáveis acima, você precisa registrar o webhook:
#
#   1. Acesse https://www.mercadopago.com.br/developers/panel/app/{APP_ID}/webhooks
#   2. Clique em "Configurar notificações"
#   3. Em "URL de produção" ou "URL de teste", configure:
#      - URL: {NEXT_PUBLIC_BASE_URL}/api/webhooks/mercadopago
#      - Eventos: Marque "Payments" (pagamentos)
#   4. Salve as configurações
#
# Exemplos de URL do webhook:
#   - Com ngrok: https://abc123.ngrok.io/api/webhooks/mercadopago
#   - Produção:  https://seu-dominio.com/api/webhooks/mercadopago
#
# 💡 Lembre-se: A URL aqui deve ser a mesma de NEXT_PUBLIC_BASE_URL + /api/webhooks/mercadopago

# ============================================================================
# RESUMO - CHECKLIST DE CONFIGURAÇÃO
# ============================================================================
# [ ] 1. Criar projeto no Supabase
# [ ] 2. Copiar URL e chaves do Supabase
# [ ] 3. Criar bucket "event-images" no Supabase Storage
# [ ] 4. Aplicar migrations do banco (ver docs/MIGRATIONS_GUIDE.md)
# [ ] 5. Gerar TICKET_QR_SECRET aleatório
# [ ] 6. Criar aplicação no Mercado Pago Developers
# [ ] 7. Copiar Access Token do Mercado Pago
# [ ] 8. (Testes de integração) Configurar ngrok e atualizar NEXT_PUBLIC_BASE_URL
# [ ] 9. Configurar webhook do Mercado Pago com a URL correta
# [ ] 10. (Produção) Atualizar NEXT_PUBLIC_BASE_URL para URL de produção
